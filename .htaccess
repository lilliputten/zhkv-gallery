# Enable Rewrite Engine
RewriteEngine On

# # Exception: Allow access to .cache.thumbs directory for serving cached thumbnails
# RewriteCond %{REQUEST_URI} !^/\.cache\.thumbs/

# Disable access to hidden files (files starting with .)
RewriteRule "(^|/)\." - [F,L]

# PHP Error Log Configuration
php_flag log_errors on
php_value error_log ".php.log"

# Enable extensionless PHP URLs
# Allow accessing /info instead of /info.php
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^/]+)/?$ $1.php [L]

# Redirect /list/{folder} to index.php?list={folder}
RewriteRule ^list/(.+)$ index.php?list=$1 [QSA,NE,L]

# Redirect view/{image} to view.php?image={image}
RewriteRule ^view/(.+)$ view.php?image=$1 [QSA,NE,L]

# Redirect thumb/{image} to thumb.php?image={image}
RewriteRule ^thumb/(.+)$ thumb.php?image=$1 [QSA,NE,L]

# Redirect preview/{image} to thumb.php?mode=preview&image={image}
RewriteRule ^preview/(.+)$ thumb.php?mode=preview&image=$1 [QSA,NE,L]

# Redirect full/{image} to thumb.php?mode=full&image={image}
RewriteRule ^full/(.+)$ thumb.php?mode=full&image=$1 [QSA,NE,L]
