# Enable Rewrite Engine
RewriteEngine On

# Enable extensionless PHP URLs
# Allow accessing /info instead of /info.php
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^/]+)/?$ $1.php [L]

# Redirect view/{image} to view.php?show={image}
RewriteRule ^view/(.+)$ view.php?show=$1 [QSA,NE,L]
